# ============================================================
# SCAM NOTIFIER — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Discord Bot ---
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# The role ID that grants admin access to bot commands
ADMIN_ROLE_ID=your_admin_role_id_here

# Private admin channel where new submissions are sent
ADMIN_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# --- Supabase ---
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here   # NOT anon key — service role
SUPABASE_ANON_KEY=your_anon_key_here

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET=a_random_32_char_secret_for_internal_calls

# --- Website (Vercel env vars) ---
# These are injected at build time / runtime
VITE_API_BASE_URL=https://your-api-domain.com
VITE_DISCORD_CLIENT_ID=your_client_id_here
VITE_REDIRECT_URI=https://your-website.vercel.app/auth/callback
